# Auth / session signing secret (any random string). A dev default is used if unset.
NEXTAUTH_SECRET=change-me-to-a-long-random-string
SECRET_KEY=change-me

# Optional: external API base (unused by the in-process store, kept for parity)
NEXT_PUBLIC_API_URL=http://localhost:8000

